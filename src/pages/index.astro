---
// src/pages/index.astro
import { locales } from "@/i18n/routing";
import Layout from "@/layouts/Layout.astro";
---

<Layout>
    <head>
        <meta name="robots" content="noindex, follow" />
    </head>
    <div
        class="relative min-h-[calc(100vh-var(--header-height))] w-full flex flex-col items-center justify-center px-4 overflow-hidden select-none"
    >
        <div
            class="relative z-10 flex flex-col items-center text-center max-w-md mix-blend-screen"
        >
            <p
                class="font-orbitron text-xs md:text-sm tracking-[0.3em] text-purple-400/80 uppercase animate-pulse mb-8"
            >
                Connecting to Network...
            </p>

            <h1
                class="font-chakrapetch text-xl md:text-2xl font-bold tracking-widest text-white uppercase mb-4"
            >
                Select Your Locale
            </h1>

            <p
                class="font-sans text-xs md:text-sm text-gray-400 mb-10 leading-relaxed max-w-xs"
            >
                言語を選択して下さい
            </p>

            <div
                class="flex flex-col sm:flex-row gap-4 w-full justify-center px-6"
            >
                <a
                    href="/ja/"
                    class="font-orbitron px-8 py-3 rounded-xl border border-purple-500/30 bg-purple-950/10 text-white font-bold tracking-widest text-sm transition-all duration-300 hover:bg-purple-500 hover:shadow-[0_0_25px_rgba(168,85,247,0.4)] hover:scale-105 active:scale-95 text-center min-w-35"
                >
                    日本語 / JA
                </a>
                <a
                    href="/en/"
                    class="font-orbitron px-8 py-3 rounded-xl border border-blue-500/30 bg-blue-950/10 text-white font-bold tracking-widest text-sm transition-all duration-300 hover:bg-blue-500 hover:shadow-[0_0_25px_rgba(59,130,246,0.4)] hover:scale-105 active:scale-95 text-center min-w-35"
                >
                    English / EN
                </a>
            </div>
        </div>
    </div>

    {
        /* 💡 スクリプト部分：Astroのロケールリストを受け取って自動リダイレクトを処理 */
    }
    {
        /* define:vars を使うことで、上の「locales」配列をフロントエンドのJSへ安全に引き渡せます */
    }
    <script define:vars={{ locales }} is:inline>
        const userLang = (navigator.language || "en")
            .toLowerCase()
            .split("-")[0];
        const targetLocale = locales.includes(userLang) ? userLang : locales[0];
        if (window.location.pathname === "/") {
            window.location.replace(`/${targetLocale}/`);
        }
    </script>
</Layout>

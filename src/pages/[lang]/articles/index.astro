---
import BasePageLayout from "@/layouts/BasePageLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

export { getStaticPaths } from "@/pages/[lang]/index.astro";

// --- 型定義 ---
export interface ComputedArticleData {
    year: string;
    month: string;
    day: string;
    slug: string;
    lang: string;
    pubDate: Date;
    previewImage: ImageMetadata | null;
    url: string;
}

export type EnrichedArticle = CollectionEntry<"articles"> & {
    computed: ComputedArticleData;
};

// --- 関数定義 ---
export async function getAllArticles(): Promise<EnrichedArticle[]> {
    // 画像のキャッシュ生成を関数内で行うことで、呼び出し時に確実に実行され、スコープエラーも防げます
    const allImageImports = import.meta.glob<{ default: ImageMetadata }>(
        "/src/contents/articles/**/*.{png,jpg,jpeg,webp,avif}",
    );

    const imageMap = new Map<string, ImageMetadata>();
    for (const [path, importFn] of Object.entries(allImageImports)) {
        const img = await importFn();
        imageMap.set(path, img.default);
    }

    const rawArticles = await getCollection("articles");

    return rawArticles
        .map((entry: EnrichedArticle) => {
            const [year, month, day, folderSlug, filename] =
                entry.id.split("/");

            // 拡張子に関わらず、フォルダ内の preview ファイルをマッチング
            const prefix = `/src/contents/articles/${year}/${month}/${day}/${folderSlug}/preview.`;
            const previewImage =
                Array.from(imageMap.entries()).find(([path]) =>
                    path.startsWith(prefix),
                )?.[1] || null;

            return {
                ...entry,
                computed: {
                    year,
                    month,
                    day,
                    slug: folderSlug,
                    lang: filename,
                    pubDate: new Date(`${year}-${month}-${day}`),
                    previewImage,
                    url: `/${filename}/articles/${year}/${month}/${day}/${folderSlug}/`,
                },
            };
        })
        .sort(
            (a: EnrichedArticle, b: EnrichedArticle) =>
                b.computed.pubDate.getTime() - a.computed.pubDate.getTime(),
        );
}

// --- コンポーネント処理 ---
const currentLocale = Astro.currentLocale || "en";
const allArticles = await getAllArticles();
const articles = allArticles.filter((a) => a.computed.lang === currentLocale);
---

<BasePageLayout title="Articles">
    <h1 class="text-2xl font-bold">{currentLocale.toUpperCase()}</h1>
    <div
        class="p-4! article-grid mt-8 grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-8"
    >
        {
            articles.map((article) => (
                <a
                    href={article.computed.url}
                    class="block overflow-hidden rounded-lg border border-gray-100 text-inherit no-underline"
                >
                    <div class="image-wrapper aspect-video overflow-hidden bg-gray-100">
                        {article.computed.previewImage ? (
                            <Image
                                src={article.computed.previewImage}
                                alt={article.data.title}
                                class="h-full w-full object-cover"
                                loading="lazy"
                            />
                        ) : (
                            <div class="flex h-full items-center justify-center text-sm text-gray-400">
                                No Image
                            </div>
                        )}
                    </div>
                    <div class="p-4!">
                        <time class="text-xs text-gray-500">
                            {article.computed.year}/{article.computed.month}/
                            {article.computed.day}
                        </time>
                        <h2 class="m-0 mt-2 text-xl font-bold">
                            {article.data.title}
                        </h2>
                    </div>
                </a>
            ))
        }
    </div>
</BasePageLayout>

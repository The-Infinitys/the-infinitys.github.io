---
import Layout from "@/layouts/Layout.astro";
export { getStaticPaths } from "../index.astro";
---

<Layout>
    <div
        class="min-h-[calc(100vh-var(--header-height))] w-full flex flex-col items-center justify-center"
    >
        <h1
            class="font-orbitron italic font-medium text-6xl text-center translate-y-[calc(-0.5*var(--header-height))]"
        >
            Contact
        </h1>
    </div>
    <div
        class="min-h-screen flex items-center justify-center bg-background/10 backdrop-blur-md"
    >
    </div>
</Layout>

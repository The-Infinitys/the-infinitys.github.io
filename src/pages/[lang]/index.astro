---
import LogoSvg from "@/assets/logo.svg?raw";
import { locales } from "@/i18n/routing";
import Layout from "@/layouts/Layout.astro";
import PixivLogo from "@/assets/sns/pixiv-logo.svg?raw";
import XLogo from "@/assets/sns/x-logo.svg?raw";
import GitHubLogo from "@/assets/sns/github-logo.svg?raw";

export async function getStaticPaths() {
    return locales.map((locale) => ({
        params: { lang: locale },
    }));
}

// 1. SNSの情報をまとめた配列を定義
const snsLinks = [
    {
        name: "X",
        url: "https://x.com/The_Infinity_s",
        icon: XLogo,
    },
    {
        name: "GitHub",
        url: "https://github.com/The-Infinitys",
        icon: GitHubLogo,
    },
    {
        name: "Pixiv",
        url: "https://www.pixiv.net/users/109461187",
        icon: PixivLogo,
    },
];
---

<Layout>
    <div
        class="min-h-[calc(100vh-var(--header-height))] w-full flex flex-col items-center pt-50! md:pt-75! px-4"
    >
        <div
            class="w-120 max-w-full h-auto text-foreground fill-current [&>svg]:w-full [&>svg]:h-auto"
        >
            <Fragment set:html={LogoSvg} />
        </div>
        <h1 class="font-orbitron mt-8! text-2xl">Beyond The Infinite</h1>
    </div>

    <div
        class="min-h-screen flex items-center justify-center bg-background/10 backdrop-blur-md"
    >
        <div
            class="flex flex-col items-center border rounded-2xl border-accent/20 bg-background/50 backdrop-blur-md m-8! md:m-16! p-6! md:p-8!"
        >
            <div class="flex flex-row items-center gap-8 md:gap-12">
                <!-- 2. 配列をループしてリンクと画像を動的に生成 -->
                {
                    snsLinks.map((sns) => (
                        <a
                            target="_blank"
                            rel="noopener noreferrer"
                            href={sns.url}
                            class="opacity-60 hover:opacity-100 transition-all duration-300 hover:scale-110"
                        >
                            <div class="w-24 h-24 [&>svg]:w-full [&>svg]:h-full [&>svg]:object-contain">
                                <Fragment set:html={sns.icon} />
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>
    </div>
</Layout>

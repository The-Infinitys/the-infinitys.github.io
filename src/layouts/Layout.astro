---
// src/layouts/Layout.astro
import { ClientRouter } from "astro:transitions";
import Header from "@/components/Header.astro";
import "../styles/global.css";
// 現在の言語を取得 (Astroのi18n設定と連動)
const lang = Astro.currentLocale || "en";
---

<!doctype html>
<html lang={lang}>
    <head>
        <ClientRouter />
    </head><body>
        <Header />
        <slot />
    </body>
</html>

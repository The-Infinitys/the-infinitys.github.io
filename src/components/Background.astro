---
// src/components/Background.astro
import BackgroundDarkness from "@/assets/background/background-darkness.svg?raw";
import BackgroundBrightness from "@/assets/background/background-brightness.svg?raw";
import UltimateDarkness from "@/assets/background/ultimate-darkness.svg?raw";
import UltimateBrightness from "@/assets/background/ultimate-brightness.svg?raw";
---

<div
    class="fixed inset-0 -z-10 bg-background overflow-hidden flex items-center justify-center pointer-events-none"
>
    <div
        class="absolute w-[120vmax] h-[120vmax] blur-[8vmin] opacity-20 pointer-events-none select-none max-w-none not-dark:hidden [&>svg]:w-full [&>svg]:h-full"
    >
        <Fragment set:html={BackgroundDarkness} />
    </div>
    <div
        class="absolute w-[120vmax] h-[120vmax] blur-[8vmin] opacity-40 pointer-events-none select-none max-w-none dark:hidden [&>svg]:w-full [&>svg]:h-full"
    >
        <Fragment set:html={BackgroundBrightness} />
    </div>
    <div
        class="absolute w-[100vmin] h-[100vmin] opacity-65 pointer-events-none select-none max-w-none z-10 not-dark:hidden [&>svg]:w-full [&>svg]:h-full"
    >
        <Fragment set:html={UltimateDarkness} />
    </div>
    <div
        class="absolute w-[100vmin] h-[100vmin] opacity-65 pointer-events-none select-none max-w-none z-10 dark:hidden [&>svg]:w-full [&>svg]:h-full"
    >
        <Fragment set:html={UltimateBrightness} />
    </div>

    <canvas id="overlay" class="absolute w-full h-full pointer-events-none"
    ></canvas>
</div>

<script>
    let currentResizeListener: (() => void) | null = null;

    // リサイズ用デバウンス関数
    function debounce(fn: () => void, delay: number) {
        let timer: number;
        return () => {
            clearTimeout(timer);
            timer = window.setTimeout(fn, delay);
        };
    }

    document.addEventListener("astro:page-load", () => {
        const canvas = document.getElementById(
            "overlay",
        ) as HTMLCanvasElement | null;
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        if (currentResizeListener) {
            window.removeEventListener("resize", currentResizeListener);
        }

        let cachedLines: any[] = [];
        let cachedPolygons: any[] = [];
        let conicGrad: CanvasGradient | null = null; // conicGradientをキャッシュ
        let width = 0,
            height = 0;

        // 計算処理（重いグラデーション生成もここに集約）
        function updateCalculations() {
            const dpr = window.devicePixelRatio || 1;
            width = window.innerWidth;
            height = window.innerHeight;
            canvas!.width = width * dpr;
            canvas!.height = height * dpr;
            ctx!.scale(dpr, dpr);

            const centerX = width / 2;
            const centerY = height / 2;
            const diagonal = Math.sqrt(width * width + height * height);
            const maxRadius = diagonal / 2;
            const baseSize = (diagonal + Math.max(width, height)) / 2;
            const minRadius = Math.min(width, height) * 0.35;
            const outerLimit = maxRadius * 1.3;

            // 1. conicGradientの事前生成
            conicGrad = ctx!.createConicGradient(0, centerX, centerY);
            conicGrad.addColorStop(0, "hsla(0, 100%, 55%, 1.0)");
            conicGrad.addColorStop(0.15, "hsla(45, 100%, 50%, 1.0)");
            conicGrad.addColorStop(0.35, "hsla(120, 100%, 45%, 1.0)");
            conicGrad.addColorStop(0.55, "hsla(190, 100%, 50%, 1.0)");
            conicGrad.addColorStop(0.7, "hsla(240, 100%, 55%, 1.0)");
            conicGrad.addColorStop(0.85, "hsla(290, 100%, 55%, 1.0)");
            conicGrad.addColorStop(1, "hsla(360, 100%, 55%, 1.0)");

            // 2. 線の計算（グラデーションを事前定義）
            cachedLines = [];
            const linesPerQuadrant = 6;
            for (let i = 0; i < linesPerQuadrant; i++) {
                const baseAngle = (i / linesPerQuadrant) * (Math.PI / 2);
                const bendFactor = Math.sin(i * 3.2) * (baseSize * 0.11);
                const crossFactor = Math.cos(i * 4.1) * (baseSize * 0.06);

                const startX =
                    centerX +
                    Math.cos(baseAngle) * outerLimit +
                    Math.sin(baseAngle) * bendFactor;
                const startY =
                    centerY -
                    (Math.sin(baseAngle) * outerLimit +
                        Math.cos(baseAngle) * bendFactor);
                const endX = centerX + Math.cos(baseAngle) * minRadius;
                const endY = centerY - Math.sin(baseAngle) * minRadius;
                const midX =
                    (startX + endX) / 2 +
                    Math.cos(baseAngle + Math.PI / 2) * bendFactor +
                    crossFactor;
                const midY =
                    (startY + endY) / 2 -
                    (Math.sin(baseAngle + Math.PI / 2) * bendFactor +
                        crossFactor);

                // ★最適化: 描画ループの外でグラデーションを作成
                const grad = ctx!.createLinearGradient(
                    startX,
                    startY,
                    endX,
                    endY,
                );
                const hue =
                    ((Math.atan2(midY - centerY, midX - centerX) * 180) /
                        Math.PI +
                        360) %
                    360;
                grad.addColorStop(0, `hsla(${hue}, 100%, 60%, 1.0)`);
                grad.addColorStop(0.65, `hsla(${hue}, 90%, 50%, 0.0)`);

                cachedLines.push({
                    startX,
                    startY,
                    midX,
                    midY,
                    endX,
                    endY,
                    grad,
                });
            }

            // 多角形の計算
            cachedPolygons = [];
            const step = Math.min(width, height) * 0.12;
            for (let r = minRadius * 1.2; r <= outerLimit + step; r += step) {
                cachedPolygons.push({
                    r,
                    sides: 8 + (((r - minRadius * 1.2) / step) % 3) * 4,
                    opacity: Math.pow(Math.min(1.0, r / maxRadius), 4.0),
                });
            }

            draw();
        }

        // 描画処理（徹底的に軽く）
        function draw() {
            ctx!.clearRect(0, 0, width, height);
            ctx!.globalCompositeOperation = "screen";

            const centerX = width / 2;
            const centerY = height / 2;
            // draw() 関数内の修正箇所

            // 1. 線（Lines）の描画用：各線ごとに個別の LinearGradient を使用（以前の方式を維持）
            ctx!.lineWidth = 1.0;
            cachedLines.forEach((line) => {
                ctx!.strokeStyle = line.grad; // updateCalculations で作った grad を再利用

                const singleLine = new Path2D();
                singleLine.moveTo(line.startX, line.startY);
                singleLine.lineTo(line.midX, line.midY);
                singleLine.lineTo(line.endX, line.endY);

                [
                    { sx: 1, sy: 1 },
                    { sx: -1, sy: 1 },
                    { sx: 1, sy: -1 },
                    { sx: -1, sy: -1 },
                ].forEach((sym) => {
                    ctx!.save();
                    ctx!.translate(centerX, centerY);
                    ctx!.scale(sym.sx, sym.sy);
                    ctx!.translate(-centerX, -centerY);
                    ctx!.stroke(singleLine);
                    ctx!.restore();
                });
            });

            // 2. 多角形（Polygons）の描画用：ここでのみ ConicGradient を使用
            if (conicGrad) {
                ctx!.strokeStyle = conicGrad;
                cachedPolygons.forEach((p, i) => {
                    ctx!.save();
                    ctx!.globalAlpha = p.opacity;

                    const poly = new Path2D();
                    // ... (多角形のパス生成処理はそのまま)
                    ctx!.stroke(poly);
                    ctx!.restore();
                });
            } // 2. 多角形の描画
            if (conicGrad) ctx!.strokeStyle = conicGrad; // 事前生成したconicGradを使用

            cachedPolygons.forEach((p, i) => {
                ctx!.save();
                ctx!.globalAlpha = p.opacity; // 透明度だけ個別に適用

                // ★最適化: パス定義にPath2Dを使用
                const poly = new Path2D();
                for (let j = 0; j < p.sides; j++) {
                    const angle =
                        (j / p.sides) * Math.PI * 2 +
                        (i * Math.PI) / (p.sides / 2);
                    const px = centerX + Math.cos(angle) * p.r;
                    const py = centerY + Math.sin(angle) * p.r;
                    if (j === 0) poly.moveTo(px, py);
                    else poly.lineTo(px, py);
                }
                poly.closePath();
                ctx!.stroke(poly);
                ctx!.restore();
            });
        }

        // 初期化
        updateCalculations();

        // リサイズ処理（デバウンスを長めに設定）
        const debouncedResize = debounce(updateCalculations, 200);
        currentResizeListener = debouncedResize;
        window.addEventListener("resize", debouncedResize);
    });
</script>

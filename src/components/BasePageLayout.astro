---
import Layout from "@/layouts/Layout.astro";

interface Props {
    // titleは必須ではなく、オプショナル（?）にしておきます
    title?: string;
}

const { title } = Astro.props;

// 💡 ページ側から slot="title" が送られてきているかチェックする
const hasCustomTitle = Astro.slots.has("title");
---

<div
    class="min-h-[calc(100vh-var(--header-height))] w-full flex flex-col items-center justify-center snap-start relative overflow-hidden"
>
    <!-- 背景用スロット -->
    <div
        class="absolute inset-0 z-0 flex items-center justify-center pointer-events-none"
    >
        <slot name="first-view" />
    </div>

    <!-- メイン要素エリア（ヘッダーの高さを考慮した位置調整） -->
    <div
        class="z-10 relative flex flex-col items-center justify-center translate-y-[calc(-0.5*var(--header-height))]"
    >
        {
            // 1. カスタムスロットがある場合は、それをそのまま展開
            hasCustomTitle ? (
                <slot name="title" />
            ) : (
                // 2. スロットが無い場合は、Propsのtitleをいつものデフォルトスタイルで表示
                <h1 class="font-orbitron italic font-medium text-6xl text-center select-none">
                    {title}
                </h1>
            )
        }
    </div>
</div>

<!-- 2枚目：詳細コンテンツエリア -->
<div
    class="min-h-screen w-full flex flex-col items-center justify-center bg-background/10 backdrop-blur-md snap-start"
>
    <slot />
</div>

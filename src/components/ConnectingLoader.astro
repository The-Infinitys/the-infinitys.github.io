---
// src/components/ConnectingLoader.astro
import Logo from "./Logo.astro";

interface Props {
    title?: string;
    className?: string;
    description?: string;
    animate?: boolean;
    showLogo?: boolean;
}

const {
    title = "Connecting",
    className = "",
    description = "Please wait a moment...",
    animate = true,
    showLogo = true,
} = Astro.props;
---

<div
    class={`flex flex-col items-center justify-center select-none ${className}`}
>
    {/* 1. 境界線が一切ない、なだらかな虹色ネオンスピナーエリア */}
    <div class="relative flex items-center justify-center mb-8!">
        {/* 外側の虹色発光リング */}
        <div
            class="absolute w-20 h-20 rounded-full animate-spin blur-xs opacity-90"
            style={{
                backgroundImage:
                    "conic-gradient(from 0deg, #ff0000, #ffff00, #00ff00, #00ffff, #0000ff, #ff00ff, #ff0000)",
                WebkitMaskImage:
                    "radial-gradient(circle, transparent 65%, black 66%)",
                maskImage:
                    "radial-gradient(circle, transparent 65%, black 66%)",
            }}
        >
        </div>
        {/* 中心部分のソリッドリングとロゴエリア */}
        <div
            class="w-14 h-14 border border-foreground/10 rounded-full flex items-center justify-center bg-background/50 backdrop-blur-[1px]"
        >
            {
                showLogo && (
                    <div class="w-10 h-10 flex items-center justify-center text-foreground/90 scale-90 transition-transform duration-300">
                        <Logo />
                    </div>
                )
            }
        </div>
    </div>

    {/* 2. テキストエリア */}
    <div class="text-center">
        <h1
            class:list={[
                "text-sm font-light tracking-[0.3em] uppercase text-foreground/90 font-orbitron",
                { "animate-pulse": animate },
            ]}
        >
            {title}
        </h1>
        {
            description && (
                <p class="text-[10px] tracking-widest text-foreground/75 mt-1 font-(family-name:--font-m-plus-1-code)">
                    {description}
                </p>
            )
        }
    </div>
</div>

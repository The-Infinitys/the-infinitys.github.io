---
import { HamburgerIcon } from "./HamburgerIcon";
import Logo from "./Logo.astro";
import { locales, type Locale } from "@/i18n/routing"; // 💡 i18n設定をインポート

const lang = Astro.currentLocale as Locale;
const navItems = [
    { name: "Home", path: `/${lang}/` },
    { name: "Article", path: `/${lang}/articles/` },
    { name: "Musics", path: `/${lang}/musics/` },
    { name: "Contact", path: `/${lang}/contact/` },
];

// 💡 現在のページURLから言語プレフィックスを差し替える関数
// 例: /ja/articles/ -> /en/articles/
const currentUrl = Astro.url.pathname;
const getSwitchLangPath = (targetLang: Locale) => {
    // パスが `/ja/articles/` のようになっている場合、最初の言語部分を置換
    const segments = currentUrl.split("/").filter(Boolean);
    if (segments[0] === lang) {
        segments[0] = targetLang;
    } else {
        segments.unshift(targetLang);
    }
    return `/${segments.join("/")}/`;
};
---

<header
    id="site-header"
    class="sticky top-0 left-0 w-full z-50 transition-all duration-300 h-(--header-height) bg-background/30 backdrop-blur-xs border-b border-foreground/10 flex items-center px-6 md:px-12 transform translate-y-0"
>
    <div
        class="relative flex items-center justify-between flex-row-reverse w-full mx-auto"
    >
        <div class="absolute left-1/2 -translate-x-1/2">
            <Logo class="h-full w-auto object-contain" />
        </div>

        <HamburgerIcon client:load class="p-5! z-50" id="menu-toggle" />
    </div>
</header>

<div
    id="full-menu"
    class="fixed top-0 right-0 h-full w-full md:w-80 z-40 bg-background/30 backdrop-blur-xs border-l border-foreground/10 flex flex-col items-center justify-center gap-8 translate-x-full transition-transform duration-500 font-orbitron"
>
    <!-- ナビゲーションメニュー -->
    <div class="flex flex-col items-center gap-8 flex-1 justify-center">
        {
            navItems.map((item) => (
                <a href={item.path} class="nav-link text-2xl font-bold italic">
                    <span class="hover:text-accent text-foreground/60 transition-all">
                        {item.name}
                    </span>
                </a>
            ))
        }
    </div>

    <!-- 🌐 多言語切り替えセレクター（メニューの下部に固定） -->
    <div
        class="mb-16! flex items-center gap-4 text-sm tracking-widest border border-foreground/10 bg-background/50 rounded-full px-6! py-2! backdrop-blur-md"
    >
        {
            locales.map((locale) => {
                const isCurrent = locale === lang;
                return isCurrent ? (
                    // 現在選択されている言語（クリック不可、アクセントカラーでハイライト）
                    <span class="text-accent font-bold uppercase select-none">
                        {locale}
                    </span>
                ) : (
                    // 切り替え先の言語リンク（現在のページのまま言語だけスイッチ）
                    <a
                        href={getSwitchLangPath(locale)}
                        class="text-foreground/40 hover:text-foreground uppercase transition-colors"
                    >
                        {locale}
                    </a>
                );
            })
        }
    </div>
</div>

<script>
    // --- 共通のアクセサー関数（再取得を保証） ---
    const getToggle = () => document.getElementById("menu-toggle");
    const getMenu = () => document.getElementById("full-menu");
    const getHeader = () => document.getElementById("site-header");

    // --- 共通の状態管理変数 ---
    let lastScrollY = window.scrollY;
    let scrollTimeout;

    // --- ヘッダー操作用関数 ---
    const updateHeaderVisibility = (isShowing) => {
        const header = getHeader();
        if (!header) return;
        header.classList.toggle("translate-y-0", isShowing);
        header.classList.toggle("-translate-y-full", !isShowing);
    };

    // --- スクロールイベントのハンドラ ---
    const handleScroll = () => {
        const menu = getMenu();
        const currentScrollY = window.scrollY;

        if (currentScrollY <= 50) {
            updateHeaderVisibility(true);
        } else if (currentScrollY > lastScrollY) {
            // 下スクロール（メニューが開いていなければ隠す）
            if (!menu?.classList.contains("translate-x-0")) {
                updateHeaderVisibility(false);
            }
        } else {
            // 上スクロール
            updateHeaderVisibility(true);
        }

        lastScrollY = currentScrollY;
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(() => updateHeaderVisibility(true), 1500);
    };

    // --- スクロールイベントの登録（一度だけ） ---
    window.addEventListener("scroll", handleScroll, { passive: true });

    // --- トグル処理の関数化 ---
    const toggleMenu = () => {
        const menu = getMenu();
        if (!menu) return;
        const isOpen = menu.classList.contains("translate-x-0");
        menu.classList.toggle("translate-x-0", !isOpen);
        menu.classList.toggle("translate-x-full", isOpen);
    };

    // --- astro:page-load 時の処理 ---
    document.addEventListener("astro:page-load", () => {
        const toggle = getToggle();
        if (!toggle) return;

        // 二重登録防止のため一度削除してから追加
        toggle.removeEventListener("click", toggleMenu);
        toggle.addEventListener("click", toggleMenu);
    });
</script>

<style is:global>
    :root {
        --header-height: 4rem;
    }
    @media (min-width: 768px) {
        :root {
            --header-height: 5rem;
        }
    }
</style>
